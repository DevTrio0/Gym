### Admin - Sign In
POST {{baseUrl}}/admin/auth/login
Content-Type: application/json

{
  "email": "admin@gmail.com",
  "password": "admin123"
}

### Admin - Forgot Password
POST {{baseUrl}}/admin/auth/forgetpassword
Content-Type: application/json

{
  "email": "admin@gmail.com"
}

### Admin - Reset Password
POST {{baseUrl}}/admin/auth/resetpassword
Content-Type: application/json

{
  "email": "admin@gmail.com",
  "newPassword": "newAdminPassword123",
  "token": "reset_1707410800000_0.5432"
}

### Admin - Register New Admin
POST {{baseUrl}}/admin/auth/register
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "John Admin",
  "email": "john.admin@gmail.com",
  "password": "adminPassword123"
}

// ============================================================================
// ADMIN DASHBOARD ENDPOINTS (Require Auth)
// ============================================================================

### Admin - Get Dashboard
GET {{baseUrl}}/admin/dashboard
Authorization: Bearer {{adminToken}}

### Admin - Get Total Users Stats
GET {{baseUrl}}/admin/stats/users
Authorization: Bearer {{adminToken}}

### Admin - Get Total Coaches Stats
GET {{baseUrl}}/admin/stats/coaches
Authorization: Bearer {{adminToken}}

### Admin - Get Total Clients Stats
GET {{baseUrl}}/admin/stats/clients
Authorization: Bearer {{adminToken}}

### Admin - Get Total Payments Stats
GET {{baseUrl}}/admin/stats/payments
Authorization: Bearer {{adminToken}}

### Admin - Get Active Coaches Stats
GET {{baseUrl}}/admin/stats/active-coaches
Authorization: Bearer {{adminToken}}

### Admin - Get Pending Coaches Stats
GET {{baseUrl}}/admin/stats/pending-coaches
Authorization: Bearer {{adminToken}}

### Admin - Get Active Clients Stats
GET {{baseUrl}}/admin/stats/active-clients
Authorization: Bearer {{adminToken}}

### Admin - Add New Coach
POST {{baseUrl}}/admin/dashboard/add-coach
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Sarah Coach",
  "email": "sarah@coach.com",
  "password": "coachPassword123"
}

### Admin - Add New Client
POST {{baseUrl}}/admin/dashboard/add-client
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Michael Client",
  "email": "michael@client.com",
  "password": "clientPassword123"
}

### Admin - Delete Account
DELETE {{baseUrl}}/admin/dashboard/delete-account
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "userId": "user_1707410800000",
  "role": "client"
}

### Admin - Deactivate Account
PUT {{baseUrl}}/admin/dashboard/deactivate-account
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "userId": "user_1707410800000",
  "role": "client"
}

### Admin - Reactivate Account
PUT {{baseUrl}}/admin/dashboard/reactivate-account
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "userId": "user_1707410800000",
  "role": "client"
}

### Admin - Approve Coach Subscription
PUT {{baseUrl}}/admin/dashboard/subscription/approve
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "coachId": "coach_1707410800000"
}

### Admin - Get Monthly Reports
GET {{baseUrl}}/admin/dashboard/reports/monthly?month=2&year=2026
Authorization: Bearer {{adminToken}}

### Admin - Get All Payments
GET {{baseUrl}}/admin/dashboard/payments
Authorization: Bearer {{adminToken}}

### Admin - Get Profit Report
GET {{baseUrl}}/admin/dashboard/profits?taxPercentage=20
Authorization: Bearer {{adminToken}}

### Admin - Get Detailed Profit Report
GET {{baseUrl}}/admin/dashboard/profits/detail?taxPercentage=20
Authorization: Bearer {{adminToken}}

### Admin - Logout
POST {{baseUrl}}/admin/exit
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "userId": "user_1"
}

// ============================================================================
// COACH SALARY MANAGEMENT (Admin Only)
// ============================================================================

### Admin - Set Coach Salary
POST {{baseUrl}}/admin/dashboard/salary/set
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "coachId": "coach_1",
  "amount": 5000,
  "description": "Monthly salary for John Coach"
}

### Admin - Get All Coach Salaries
GET {{baseUrl}}/admin/dashboard/salary/all
Authorization: Bearer {{adminToken}}

### Admin - Get Single Coach Salary
GET {{baseUrl}}/admin/dashboard/salary/coach_1
Authorization: Bearer {{adminToken}}

### Admin - Pay Coach Salary
POST {{baseUrl}}/admin/dashboard/salary/pay
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "coachId": "coach_1",
  "amount": 5000,
  "notes": "February 2026 salary payment"
}

### Admin - Get Coach Payment History
GET {{baseUrl}}/admin/dashboard/salary/history/coach_1?limit=12
Authorization: Bearer {{adminToken}}

### Admin - Get All Salary Payments
GET {{baseUrl}}/admin/dashboard/salary-payments/all?limit=20
Authorization: Bearer {{adminToken}}

### Admin - Generate Salary Report
GET {{baseUrl}}/admin/dashboard/salary/report
Authorization: Bearer {{adminToken}}

