@baseUrl = http://localhost:5000
@adminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJ1c2VyXzEiLCJyb2xlIjoiYWRtaW4iLCJpYXQiOjE3MDc0MTA4MDB9.xxx
@coachToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJjb2FjaF8xIiwicm9sZSI6ImNvYWNoIiwiaWF0IjoxNzA3NDEwODAwfQ.xxx
@clientToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJjbGllbnRfMSIsInJvbGUiOiJjbGllbnQiLCJpYXQiOjE3MDc0MTA4MDB9.xxx

// ============================================================================
// SHARED ENDPOINTS (No Authentication Required)
// ============================================================================

### Load Coach Frontend
GET {{baseUrl}}/coach/start

### Load Admin Frontend
GET {{baseUrl}}/admin/start

### Load Client Frontend
GET {{baseUrl}}/client/start

// ============================================================================
// COACH AUTHENTICATION ENDPOINTS
// ============================================================================

### Coach - Login Check (Account Exists)
POST {{baseUrl}}/coach/auth/login
Content-Type: application/json

{
  "email": "john@coach.com"
}

### Coach - Sign In
POST {{baseUrl}}/coach/auth/signin
Content-Type: application/json

{
  "email": "john@coach.com",
  "password": "admin123"
}

### Coach - Forgot Password
POST {{baseUrl}}/coach/auth/forgetpassword
Content-Type: application/json

{
  "email": "john@coach.com"
}

### Coach - Reset Password
POST {{baseUrl}}/coach/auth/resetpassword
Content-Type: application/json

{
  "email": "john@coach.com",
  "newPassword": "newPassword123",
  "token": "reset_1770698513498_0.11258575973923501"
}

// ============================================================================
// COACH DASHBOARD ENDPOINTS (Require Auth)
// ============================================================================

### Coach - Get Dashboard
GET {{baseUrl}}/coach/dashboard
Authorization: Bearer {{coachToken}}

### Coach - Get All Clients
GET {{baseUrl}}/coach/dashboard/clients
Authorization: Bearer {{coachToken}}

### Coach - Add Diet Plan for Client
POST {{baseUrl}}/coach/dashboard/add-diet
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "clientId": "client_1",
  "dietPlan": {
    "breakfast": "500 cal - Oats with eggs and berries",
    "lunch": "700 cal - Grilled chicken breast with brown rice and broccoli",
    "dinner": "500 cal - Salmon with sweet potato and asparagus",
    "snacks": "300 cal - Protein shake or Greek yogurt"
  }
}

### Coach - Add Weekly Training Plan
POST {{baseUrl}}/coach/dashboard/add-training
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "clientId": "client_1",
  "week": 1,
  "trainingPlan": {
    "monday": "Chest & Triceps - 45 min - Bench Press, Incline Dumbbell Press, Tricep Dips",
    "tuesday": "Back & Biceps - 45 min - Deadlifts, Pull-ups, Barbell Rows",
    "wednesday": "Rest day - Light stretching and mobility work",
    "thursday": "Legs & Core - 50 min - Squats, Leg Press, Core exercises",
    "friday": "Shoulders & Arms - 45 min - Shoulder Press, Lateral Raises",
    "saturday": "Full Body Circuit - 60 min - Mix of cardio and strength",
    "sunday": "Rest day - Recovery"
  }
}

### Coach - Add Note for Client
POST {{baseUrl}}/coach/dashboard/clients/client_1/add-note
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "note": "Jane is showing excellent progress with deadlifts. Increased weight by 10kg. Continue with current routine and focus on form."
}

### Coach - Get Client Progress
GET {{baseUrl}}/coach/dashboard/clients/client_1/progress
Authorization: Bearer {{coachToken}}

### Coach - Logout
POST {{baseUrl}}/coach/exit
Authorization: Bearer {{coachToken}}
Content-Type: application/json

{
  "userId": "coach_1"
}

