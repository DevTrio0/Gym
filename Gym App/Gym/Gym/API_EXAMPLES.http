// ============================================================================
// CLIENT DASHBOARD ENDPOINTS (Require Auth)
// ============================================================================

### Client - Get Dashboard
GET {{baseUrl}}/client/dashboard
Authorization: Bearer {{clientToken}}

### Client - Welcome Page
GET {{baseUrl}}/client/welcome
Authorization: Bearer {{clientToken}}

### Client - Book Workout
POST {{baseUrl}}/client/dashboard/book-workout
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "workoutId": "training_1",
  "agree": true
}

### Client - Select Subscription Plan
POST {{baseUrl}}/client/dashboard/subscription/select-plan
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "planId": "plan_1",
  "method": "gym"
}

### Client - Make Payment
POST {{baseUrl}}/client/dashboard/subscription/payment
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "planId": "plan_1",
  "paymentMethod": "credit_card",
  "paymentDetails": {
    "method": "gym",
    "cardNumber": "4532_xxxx_xxxx_xxxx",
    "cardholderName": "Jane Client"
  }
}

### Client - Renew or Change Subscription
POST {{baseUrl}}/client/dashboard/subscription/renew-or-change
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "newPlanId": "plan_2"
}

### Client - Get Weekly Workouts
GET {{baseUrl}}/client/dashboard/workout-week?weekId=1
Authorization: Bearer {{clientToken}}

### Client - Get Progress
GET {{baseUrl}}/client/dashboard/progress
Authorization: Bearer {{clientToken}}

### Client - Update Progress
POST {{baseUrl}}/client/dashboard/progress/update
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "dietProgress": "Excellent",
  "workoutProgress": "85%",
  "notes": "Feeling stronger, increased bench press weight"
}

### Client - Logout
POST {{baseUrl}}/client/exit
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "userId": "client_1"
}

