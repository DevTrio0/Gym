  Role: client
  Coach: coach_1
  Subscription: Active (plan_1)
*/

// ============================================================================
// COMMON RESPONSE PATTERNS
// ============================================================================

/*
Success Response Format:
{
  "status": "success",
  "message": "...",
  "data": {...}
}

Error Response Format:
{
  "status": "error",
  "message": "Error description"
}

Authentication Error:
{
  "status": "error",
  "message": "Unauthorized"
}
*/
